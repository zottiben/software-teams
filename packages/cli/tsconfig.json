{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "lib-esm",
    "rootDir": "src",
    "declaration": true,
    "composite": true,
    "types": ["@types/bun"]
  },
  "include": ["src/**/*"]
}
