{
  "allowedTools": [
    "Read",
    "Write",
    "Edit",
    "MultiEdit",
    "Glob",
    "Grep",
    "Task",
    "Bash(bun:*)",
    "Bash(git:*)",
    "Bash(gh:*)",
    "Bash(npm:*)",
    "Bash(npx:*)",
    "Bash(mkdir:*)",
    "Bash(rm:*)",
    "Bash(software-teams:*)"
  ],
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/state-session-context.sh"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/quality-gate.sh"
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/team-task-quality-gate.sh"
          }
        ]
      }
    ]
  }
}
